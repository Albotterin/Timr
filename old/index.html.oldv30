<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zeitmessung & Bestenliste</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        :root {
            --bg-color: #f4f7f6;
            --card-bg: #ffffff;
            --primary: #2c3e50;
            --accent: #3498db;
            --danger: #e74c3c;
            --success: #2ecc71;
            --warning: #f1c40f;
            --penalty: #f39c12;
            --bonus: #9b59b6;
            --status-color: #7f8c8d;
            --text: #333333;
            --text-light: #7f8c8d;
            --border-color: #dddddd;
            --item-hover: #fafafa;
        }

        [data-theme="dark"] {
            --bg-color: #1a1a1a;
            --card-bg: #2d2d2d;
            --primary: #ecf0f1;
            --accent: #5dade2;
            --danger: #e74c3c;
            --success: #2ecc71;
            --warning: #f1c40f;
            --penalty: #e67e22;
            --bonus: #8e44ad;
            --status-color: #95a5a6;
            --text: #e0e0e0;
            --text-light: #95a5a6;
            --border-color: #444444;
            --item-hover: #3a3a3a;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text);
            margin: 0; padding: 20px;
            display: flex; flex-direction: column; align-items: center;
            transition: background-color 0.3s, color 0.3s;
        }

        *, *::before, *::after { box-sizing: border-box; }

        /* Top Bar Layout für Whitelabel oben links und Theme-Toggle oben rechts */
        .top-bar { 
            width: 100%; 
            max-width: 600px; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            margin-bottom: 15px; 
            gap: 15px;
        }
        
        .whitelabel-title {
            font-size: 1.2rem;
            font-weight: bold;
            color: var(--primary);
            text-decoration: none;
            transition: color 0.2s;
        }
        .whitelabel-title[href]:hover {
            color: var(--accent);
        }

        .theme-toggle-btn {
            background: var(--card-bg); border: 2px solid var(--border-color); color: var(--text);
            padding: 8px 14px; border-radius: 20px; cursor: pointer; font-weight: 600; font-size: 0.9rem;
            display: flex; align-items: center; gap: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); transition: all 0.2s;
        }
        .theme-toggle-btn:hover { opacity: 0.9; transform: translateY(-1px); }

        .container { width: 100%; max-width: 600px; display: flex; flex-direction: column; gap: 25px; }
        .card { background: var(--card-bg); border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); padding: 25px; transition: background-color 0.3s, box-shadow 0.3s; }
        
        .event-management-block { width: 100%; }
        .event-select { width: 100%; padding: 12px; font-size: 1.1rem; font-weight: bold; color: var(--primary); border: 2px solid var(--border-color); border-radius: 8px; background-color: var(--card-bg); outline: none; cursor: pointer; display: block; margin-bottom: 12px; }
        
        .event-buttons-row { display: table; width: 100%; table-layout: fixed; }
        .event-btn-cell { display: table-cell; padding: 0 5px; }
        .event-btn-cell:first-child { padding-left: 0; }
        .event-btn-cell:last-child { padding-right: 0; }
        
        .btn-event-action { color: white; border: none; width: 100%; height: 48px; border-radius: 8px; font-size: 1.3rem; font-weight: bold; cursor: pointer; display: block; transition: opacity 0.2s; text-align: center; }
        .btn-event-action:hover { opacity: 0.9; }
        .btn-create-event { background-color: var(--accent); font-size: 1.5rem; }
        .btn-lock-event { background-color: #2c3e50; }
        .btn-lock-event.is-locked { background-color: var(--danger); }
        .btn-delete-event { background-color: var(--danger); }

        .tabs-container { display: flex; border-bottom: 2px solid var(--border-color); margin-bottom: 20px; gap: 5px; }
        .tab-btn { flex: 1; padding: 12px; background: none; border: none; color: var(--text-light); font-weight: bold; font-size: 1rem; cursor: pointer; border-radius: 8px 8px 0 0; transition: all 0.2s; }
        .tab-btn:hover { background-color: var(--item-hover); }
        .tab-btn.active { color: var(--accent); border-bottom: 3px solid var(--accent); background-color: var(--item-hover); }
        .tab-content { display: none; }
        .tab-content.active { display: block; }

        #pdfEventTitle { display: none; margin: 0 0 10px 0; color: #2c3e50; font-size: 1.8rem; text-align: center; }
        .card-header-container { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--bg-color); padding-bottom: 10px; margin-bottom: 15px; gap: 10px; }
        h2 { margin: 0; color: var(--primary); font-size: 1.5rem; flex-grow: 1; }
        .header-actions { display: flex; gap: 8px; }

        .dropdown { position: relative; display: inline-block; }
        .dropdown-content { 
            display: none; position: absolute; right: 0; top: 100%; background-color: var(--card-bg); 
            min-width: 160px; box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.15); border: 1px solid var(--border-color);
            border-radius: 6px; z-index: 10; overflow: hidden; margin-top: 5px;
        }
        .dropdown-content button { 
            color: var(--text); padding: 12px 16px; text-decoration: none; display: block; 
            width: 100%; border: none; background: none; text-align: left; font-size: 0.9rem; 
            font-weight: 500; cursor: pointer; transition: background-color 0.2s;
        }
        .dropdown-content button:hover { background-color: var(--item-hover); }
        .dropdown:hover .dropdown-content { display: block; }

        .btn-action-header { color: white; border: none; padding: 10px 14px; border-radius: 6px; font-size: 0.85rem; font-weight: bold; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: opacity 0.2s; }
        .btn-action-header:hover { opacity: 0.9; }
        .btn-export-dropdown { background-color: #8e44ad; }
        .btn-data-dropdown { background-color: #27ae60; }

        .leaderboard-list { list-style: none; padding: 0; margin: 0; }
        .leaderboard-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 10px; border-bottom: 1px solid var(--border-color); transition: background 0.2s; gap: 10px; }
        .leaderboard-item:last-child { border-bottom: none; }
        .leaderboard-item:hover { background-color: var(--item-hover); }

        .runner-info { display: flex; align-items: center; gap: 12px; }
        .rank { font-weight: bold; color: var(--accent); width: 25px; }
        .runner-name { font-weight: 500; }
        
        .stats-badges { display: flex; flex-wrap: wrap; gap: 6px; font-size: 0.75rem; margin-top: 4px; font-weight: 600; }
        .badge { padding: 2px 6px; border-radius: 4px; color: white; }
        .badge-penalty { background-color: var(--penalty); }
        .badge-bonus { background-color: var(--bonus); }
        .badge-status { background-color: var(--status-color); }

        .right-side-container { display: flex; align-items: center; gap: 10px; }
        .runner-time { font-family: 'Courier New', Courier, monospace; font-weight: bold; color: var(--primary); }

        .action-btn { background: none; border: none; font-size: 1.1rem; cursor: pointer; transition: color 0.2s; padding: 0 4px; color: var(--text-light); }
        .edit-btn:hover { color: var(--accent); }
        .delete-btn:hover { color: var(--danger); }
        .empty-state { text-align: center; color: var(--text-light); font-style: italic; padding: 10px 0; }

        .form-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
        .input-inline-group { display: flex; gap: 8px; }
        .input-inline-group input { flex: 1; }
        label { font-weight: 600; color: var(--primary); }

        input[type="text"], input[type="number"], select { padding: 12px; border: 2px solid var(--border-color); background-color: var(--card-bg); color: var(--text); border-radius: 8px; font-size: 1rem; outline: none; transition: border-color 0.2s, background-color 0.3s, color 0.3s; }
        input[type="text"]:focus, input[type="number"]:focus, select:focus { border-color: var(--accent); }

        .time-inputs-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }
        .time-input-container { display: flex; flex-direction: column; align-items: center; gap: 4px; font-size: 0.75rem; color: var(--text-light); font-weight: 600; }
        .time-inputs-row input { width: 100%; box-sizing: border-box; text-align: center; padding: 10px 5px; }

        .stopwatch-display { font-family: 'Courier New', Courier, monospace; font-size: 3rem; text-align: center; font-weight: bold; color: var(--primary); margin: 20px 0; letter-spacing: 2px; }
        .adjustment-display { text-align: center; font-weight: 600; height: 20px; margin-bottom: 15px; font-size: 1.1rem; }
        .adjustment-display.penalty { color: var(--danger); }
        .adjustment-display.bonus { color: var(--success); }
        .adjustment-display.status-info { color: var(--status-color); }

        .btn-group { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }
        .btn { padding: 12px; border: none; border-radius: 8px; font-size: 1rem; font-weight: bold; cursor: pointer; transition: opacity 0.2s, transform 0.1s; color: white; display: flex; justify-content: center; align-items: center; }
        .btn:active { transform: scale(0.98); }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

        .btn-start { background-color: var(--success); }
        .btn-pause { background-color: var(--warning); color: #333; }
        .btn-stop { background-color: var(--danger); }
        .btn-popup-view { background-color: #34495e; grid-column: span 2; }
        .btn-save { background-color: var(--accent); grid-column: span 2; }

        .management-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; margin-top: 10px; }
        .btn-add-type { color: white; border: none; width: 32px; height: 32px; border-radius: 50%; font-size: 1.2rem; font-weight: bold; cursor: pointer; display: flex; justify-content: center; align-items: center; transition: opacity 0.2s; }
        .btn-add-type.penalty-add { background-color: var(--penalty); }
        .btn-add-type.bonus-add { background-color: var(--bonus); }

        .dynamic-button-group { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 15px; }
        .custom-btn-container { border-radius: 8px; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.05); color: white; display: inline-flex; align-items: center; }
        .custom-btn-container.type-penalty { background-color: var(--penalty); }
        .custom-btn-container.type-bonus { background-color: var(--bonus); }
        .custom-btn-container.type-status { background-color: var(--status-color); }

        .btn-custom-action { background: none; border: none; color: white; padding: 12px 15px; font-size: 0.95rem; font-weight: bold; cursor: pointer; transition: background-color 0.2s; }
        .btn-custom-action:hover:not(:disabled) { background-color: rgba(0, 0, 0, 0.1); }
        .btn-custom-action:disabled { opacity: 0.4; cursor: not-allowed; }

        .delete-custom-type-btn { background: rgba(0, 0, 0, 0.15); border: none; color: white; padding: 0 10px; align-self: stretch; cursor: pointer; font-size: 1rem; transition: background-color 0.2s; }
        .delete-custom-type-btn:hover { background-color: var(--danger); }

        .group-runners-list { display: flex; flex-direction: column; gap: 12px; margin-top: 15px; }
        .group-runner-row { background: var(--bg-color); padding: 15px; border-radius: 8px; border-left: 4px solid var(--accent); }
        .group-runner-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
        .group-runner-name-label { font-weight: bold; font-size: 1.1rem; }
        .group-time-display { font-family: 'Courier New', monospace; font-size: 1.6rem; font-weight: bold; }
        .group-mini-btn-row { display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap; }
        .group-mini-btn { flex: 1; min-width: 70px; padding: 8px; font-size: 0.85rem; }

        .custom-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); justify-content: center; align-items: center; z-index: 1000; }
        .modal-content { background: var(--card-bg); padding: 25px; border-radius: 12px; width: 90%; max-width: 420px; box-shadow: 0 5px 20px rgba(0,0,0,0.2); max-height: 90vh; overflow-y: auto; }
        .modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; }

        .pdf-export-mode { padding: 30px !important; color: #000000 !important; background: #ffffff !important; }
        .pdf-export-mode .runner-time { color: #000000 !important; font-weight: 900 !important; }
        .pdf-export-mode .runner-name { color: #000000 !important; font-weight: bold !important; }
        .pdf-export-mode .rank { color: #111111 !important; }

        .app-footer {
            margin-top: 40px;
            margin-bottom: 20px;
            font-size: 0.85rem;
            color: var(--text-light);
            text-align: center;
            font-weight: 500;
        }
    </style>
</head>
<body>

    <div class="top-bar">
        <a id="whitelabelTitle" class="whitelabel-title">⏱️ Zeitmessung</a>
        
        <button class="theme-toggle-btn" id="themeToggleBtn" onclick="toggleTheme()">
            <span id="themeIcon">🌙</span> <span id="themeText">Dark Mode</span>
        </button>
    </div>

    <input type="file" id="jsonImportInput" accept=".json" style="display: none;" onchange="importJSONData(event)">

    <div class="container">
        <div class="card event-setting">
            <div class="event-management-block">
                <select id="eventSelect" class="event-select" onchange="handleEventSelectChange()"></select>
                <div class="event-buttons-row">
                    <div class="event-btn-cell">
                        <button class="btn-event-action btn-create-event" onclick="openEventCreationModal()" title="Neuen Lauf anlegen">+</button>
                    </div>
                    <div class="event-btn-cell">
                        <button id="lockEventBtn" class="btn-event-action btn-lock-event" onclick="toggleLockCurrentEvent()" title="Lauf abschließen/öffnen">🔒</button>
                    </div>
                    <div class="event-btn-cell">
                        <button class="btn-event-action btn-delete-event" onclick="deleteCurrentEvent()" title="Diesen Lauf löschen">🗑️</button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="card" id="leaderboardCard">
            <h1 id="pdfEventTitle">Bestenliste</h1>
            <div class="card-header-container" id="cardHeader">
                <h2>🏆 Bestenliste</h2>
                <div class="header-actions">
                    <div class="dropdown">
                        <button class="btn-action-header btn-export-dropdown">📤 Export</button>
                        <div class="dropdown-content">
                            <button onclick="exportToPDF()">PDF speichern</button>
                            <button onclick="shareAsImage()">Bild teilen/speichern</button>
                        </div>
                    </div>
                    <div class="dropdown">
                        <button class="btn-action-header btn-data-dropdown">💾 Daten</button>
                        <div class="dropdown-content">
                            <button onclick="exportJSONData()">Export (JSON)</button>
                            <button onclick="triggerJSONImport()">Import (JSON)</button>
                        </div>
                    </div>
                </div>
            </div>
            <ol id="leaderboard" class="leaderboard-list"></ol>
        </div>

        <div class="card" id="timingCard">
            <div class="tabs-container">
                <button id="tabSingleBtn" class="tab-btn active" onclick="switchTab('single')">👤 Einzelläufer</button>
                <button id="tabGroupBtn" class="tab-btn" onclick="switchTab('group')">👥 Gruppenlauf</button>
            </div>
            
            <div id="tabSingleContent" class="tab-content active">
                <div class="form-group">
                    <label for="runnerName">Name des Läufers:</label>
                    <input type="text" id="runnerName" placeholder="z.B. Max Mustermann" autocomplete="off" oninput="syncPopupRunnerName()">
                </div>

                <div class="stopwatch-display" id="display">00:00:00.00</div>
                <div id="adjustmentNotice" class="adjustment-display"></div>

                <div class="btn-group">
                    <button class="btn btn-start" id="startBtn" onclick="toggleTimer()">Start</button>
                    <button class="btn btn-stop" id="stopBtn" onclick="stopTimer()" disabled>Stop</button>
                </div>

                <div class="management-header">
                    <label>Strafsekunden hinzufügen (+):</label>
                    <button id="addPenaltyTypeBtn" class="btn-add-type penalty-add" onclick="openModal('add_btn_penalty')">+</button>
                </div>
                <div id="dynamicPenaltyGroup" class="dynamic-button-group"></div>

                <div class="management-header">
                    <label>Bonuszeit abziehen (-):</label>
                    <button id="addBonusTypeBtn" class="btn-add-type bonus-add" onclick="openModal('add_btn_bonus')">+</button>
                </div>
                <div id="dynamicBonusGroup" class="dynamic-button-group"></div>

                <div class="management-header"><label>Spezial-Status setzen:</label></div>
                <div class="dynamic-button-group">
                    <div class="custom-btn-container type-status"><button id="statusBtnDNS" class="btn-custom-action" onclick="handleStatusSet('DNS')">DNS</button></div>
                    <div class="custom-btn-container type-status"><button id="statusBtnDNF" class="btn-custom-action" onclick="handleStatusSet('DNF')">DNF</button></div>
                    <div class="custom-btn-container type-status"><button id="statusBtnDNQ" class="btn-custom-action" disabled onclick="handleStatusSet('DNQ')">DNQ</button></div>
                </div>

                <div class="btn-group" style="margin-top:20px;">
                    <button class="btn btn-save" id="saveBtn" onclick="saveRun()" disabled>Lauf Speichern</button>
                </div>
            </div>

            <div id="tabGroupContent" class="tab-content">
                <div class="form-group" id="groupSetupForm">
                    <label for="groupRunnerInput">Läufer zur Gruppe hinzufügen:</label>
                    <div class="input-inline-group">
                        <input type="text" id="groupRunnerInput" placeholder="Name eingeben...">
                        <button class="btn btn-start" style="padding: 0 20px;" onclick="addRunnerToGroup()">Hinzufügen</button>
                    </div>
                </div>

                <div id="groupMassActionRow" style="display: none; margin-bottom: 15px;">
                    <button class="btn btn-start" id="groupMassStartBtn" style="width: 100%;" onclick="startAllGroupRunners()">🏁 Alle Starten</button>
                </div>

                <div id="groupRunnersContainer" class="group-runners-list"></div>
            </div>
            
            <div class="btn-group" style="margin-top:20px;">
                <button class="btn btn-popup-view" onclick="openScreenPopup()">📺 Leinwand-Ansicht öffnen</button>
            </div>
        </div>
    </div>

    <footer class="app-footer" id="appFooter">Version: Lädt...</footer>

    <div id="customModal" class="custom-modal">
        <div class="modal-content">
            <h3 id="modalTitle" style="margin-top:0;">Neuen Button anlegen</h3>
            <div class="form-group">
                <label for="newBtnName">Bezeichnung / Name:</label>
                <input type="text" id="newBtnName" placeholder="z.B. Torfehler">
            </div>
            <div class="form-group">
                <label for="newBtnSeconds">Zeit (in Sekunden):</label>
                <input type="number" id="newBtnSeconds" placeholder="z.B. 5" min="1">
            </div>
            <div class="modal-actions">
                <button class="btn" style="background-color: var(--text-light);" onclick="closeModal()">Abbrechen</button>
                <button class="btn" style="background-color: var(--success);" onclick="createNewButton()">Erstellen</button>
            </div>
        </div>
    </div>

    <div id="eventModal" class="custom-modal">
        <div class="modal-content">
            <h3 style="margin-top:0;">Neuen Lauf (Event) anlegen</h3>
            <div class="form-group">
                <label for="newEventName">Name des Events:</label>
                <input type="text" id="newEventName" placeholder="z.B. Sommerlauf 2026">
            </div>
            <div class="modal-actions">
                <button class="btn" style="background-color: var(--text-light);" onclick="closeEventModal()">Abbrechen</button>
                <button class="btn" style="background-color: var(--success);" onclick="createNewEvent()">Anlegen</button>
            </div>
        </div>
    </div>

    <div id="editModal" class="custom-modal">
        <div class="modal-content">
            <h3 style="margin-top:0;">Eintrag bearbeiten</h3>
            <input type="hidden" id="editRunId">
            <div class="form-group">
                <label for="editRunnerName">Name des Läufers:</label>
                <input type="text" id="editRunnerName">
            </div>
            <div class="form-group">
                <label for="editStatus">Status:</label>
                <select id="editStatus" onchange="toggleEditTimeField()">
                    <option value="REGULÄR">Regulär</option>
                    <option value="DNQ">DNQ</option>
                    <option value="DNF">DNF</option>
                    <option value="DNS">DNS</option>
                </select>
            </div>
            
            <div class="form-group" id="editTimeGroup">
                <label>Reine Laufzeit:</label>
                <div class="time-inputs-row">
                    <div class="time-input-container"><input type="number" id="editHours" min="0"><span style="font-size:0.7rem">Std</span></div>
                    <div class="time-input-container"><input type="number" id="editMinutes" min="0"><span style="font-size:0.7rem">Min</span></div>
                    <div class="time-input-container"><input type="number" id="editSeconds" min="0"><span style="font-size:0.7rem">Sek</span></div>
                    <div class="time-input-container"><input type="number" id="editHundredths" min="0"><span style="font-size:0.7rem">1/100</span></div>
                </div>
            </div>

            <div class="form-group">
                <label for="editPenaltyCount">Anzahl Strafen:</label>
                <input type="number" id="editPenaltyCount" min="0">
            </div>
            <div class="form-group">
                <label for="editPenaltyTime">Strafzeit Gesamt (Sekunden):</label>
                <input type="number" id="editPenaltyTime" min="0">
            </div>
            <div class="form-group">
                <label for="editBonusCount">Anzahl Boni:</label>
                <input type="number" id="editBonusCount" min="0">
            </div>
            <div class="form-group">
                <label for="editBonusTime">Bonuszeit Gesamt (Sekunden):</label>
                <input type="number" id="editBonusTime" min="0">
            </div>

            <div class="modal-actions">
                <button class="btn" style="background-color: var(--text-light);" onclick="closeEditModal()">Abbrechen</button>
                <button class="btn" style="background-color: var(--accent);" onclick="submitEditRun()">Speichern</button>
            </div>
        </div>
    </div>

    <script>
        let isRunning = false, isPaused = false;
        let startTime = 0, elapsedBeforePause = 0, timerInterval = null, currentTotalMs = 0;
        let penaltyCount = 0, penaltyTime = 0, bonusCount = 0, bonusTime = 0, currentStatus = "REGULÄR";
        let currentModalMode = 'add_btn_penalty', popupWindow = null;
        
        let currentEvent = 'Standardlauf';
        let eventList = ['Standardlauf'];
        let runs = [];
        let lockedEvents = [];
        let activeTab = 'single';

        let groupRunners = [];
        let groupInterval = null;

        let penaltyTypes = JSON.parse(localStorage.getItem('runnerPenaltyTypes')) || [];
        let bonusTypes = JSON.parse(localStorage.getItem('runnerBonusTypes')) || [];

        window.onload = function() {
            eventList = JSON.parse(localStorage.getItem('runnerEventList')) || ['Standardlauf'];
            currentEvent = localStorage.getItem('runnerCurrentEventName') || 'Standardlauf';
            lockedEvents = JSON.parse(localStorage.getItem('runnerLockedEvents')) || [];
            
            buildEventSelectMenu();
            loadRunsForCurrentEvent();
            renderCustomButtons('penalty');
            renderCustomButtons('bonus');
            initTheme();
            resetForm();
            loadVersionInfo();
            loadWhitelabelInfo(); // Whitelabel Titel laden
        };

        window.onunload = function() { if (popupWindow) popupWindow.close(); };

        // --- Whitelabel Titel auslesen ---
        function loadWhitelabelInfo() {
            fetch('whitelabel.info')
                .then(response => {
                    if (!response.ok) throw new Error('Whitelabel-Datei nicht gefunden');
                    return response.text();
                })
                .then(text => {
                    const lines = text.split('\n');
                    let title = "⏱️ Zeitmessung";
                    let url = "";

                    lines.forEach(line => {
                        const trimmedLine = line.trim();
                        if (trimmedLine.startsWith('Title=')) {
                            title = trimmedLine.replace('Title=', '').trim();
                        } else if (trimmedLine.startsWith('URL=')) {
                            url = trimmedLine.replace('URL=', '').trim();
                        }
                    });

                    const titleElement = document.getElementById('whitelabelTitle');
                    titleElement.innerText = title;
                    if (url) {
                        titleElement.setAttribute('href', url);
                        titleElement.setAttribute('target', '_blank'); // Öffnet Link in neuem Tab
                    } else {
                        titleElement.removeAttribute('href');
                    }
                })
                .catch(error => {
                    console.log('Whitelabel-Datei konnte nicht geladen werden, verwende Standard:', error);
                    const titleElement = document.getElementById('whitelabelTitle');
                    titleElement.innerText = "⏱️ Zeitmessung";
                    titleElement.removeAttribute('href');
                });
        }

        // --- Versionsnummer auslesen ---
        function loadVersionInfo() {
            fetch('ver.info')
                .then(response => {
                    if (!response.ok) throw new Error('Datei nicht gefunden');
                    return response.text();
                })
                .then(versionText => {
                    const cleanVersion = versionText.trim();
                    document.getElementById('appFooter').innerText = `Version: ${cleanVersion}`;
                })
                .catch(error => {
                    console.log('Fehler beim Laden der ver.info:', error);
                    document.getElementById('appFooter').innerText = 'Version: Lokal / Unbekannt';
                });
        }

        function switchTab(mode) {
            if (isRunning || groupRunners.some(r => r.state === 'running' || r.state === 'paused')) {
                alert("Wechsel während aktiver Messung blockiert!"); return;
            }
            activeTab = mode;
            document.getElementById('tabSingleBtn').classList.toggle('active', mode === 'single');
            document.getElementById('tabGroupBtn').classList.toggle('active', mode === 'group');
            document.getElementById('tabSingleContent').classList.toggle('active', mode === 'single');
            document.getElementById('tabGroupContent').classList.toggle('active', mode === 'group');
            if(popupWindow && !popupWindow.closed) { syncPopupRunnerName(); syncPopupNotice(); }
        }

        // --- Gruppenlauf Kernlogik ---
        function addRunnerToGroup() {
            const input = document.getElementById('groupRunnerInput');
            const name = input.value.trim();
            if(!name) return;
            groupRunners.push({
                id: Date.now() + Math.random(), name: name, state: 'idle',
                timeMs: 0, startTime: 0, elapsed: 0, status: 'REGULÄR',
                penalties: { count: 0, time: 0 }, bonuses: { count: 0, time: 0 }
            });
            input.value = '';
            renderGroupRunners();
            document.getElementById('groupMassActionRow').style.display = 'block';
        }

        function startAllGroupRunners() {
            if(groupRunners.length === 0) return;
            const now = Date.now();
            groupRunners.forEach(r => {
                if(r.state === 'idle') { r.state = 'running'; r.startTime = now; }
            });
            document.getElementById('groupSetupForm').style.display = 'none';
            document.getElementById('groupMassActionRow').style.display = 'none';
            startGroupTicker();
            renderGroupRunners();
        }

        function startGroupTicker() {
            if(groupInterval) clearInterval(groupInterval);
            groupInterval = setInterval(() => {
                const now = Date.now();
                groupRunners.forEach(r => {
                    if(r.state === 'running') { r.timeMs = now - r.startTime + r.elapsed; }
                });
                updateGroupLiveDisplays();
            }, 10);
        }

        function updateGroupLiveDisplays() {
            groupRunners.forEach(r => {
                const el = document.getElementById(`gDisplay_${r.id}`);
                if(el) el.innerText = r.status === 'DNF' || r.status === 'DNS' ? r.status : formatTime(r.timeMs);
            });
            if (popupWindow && !popupWindow.closed) syncPopupLeaderboard();
        }

        function toggleGroupRunnerTimer(id) {
            const r = groupRunners.find(runner => runner.id === id);
            if(!r || r.state === 'stopped') return;
            if(r.state === 'running') {
                r.state = 'paused'; r.elapsed = r.timeMs;
            } else {
                r.state = 'running'; r.startTime = Date.now();
            }
            renderGroupRunners();
        }

        // --- Timer anhalten ---
        function stopGroupRunnerTimer(id) {
            const r = groupRunners.find(runner => runner.id === id);
            if(!r) return;
            r.state = 'stopped';
            renderGroupRunners();
            if(groupRunners.every(runner => runner.state === 'stopped')) {
                clearInterval(groupInterval);
            }
        }

        function adjustGroupTime(id, mode, secs) {
            const r = groupRunners.find(runner => runner.id === id);
            if(!r || r.status === 'DNF' || r.status === 'DNS') return;
            if(mode === 'penalty') {
                r.penalties.count++; r.penalties.time += secs; r.timeMs += (secs * 1000); r.elapsed += (secs * 1000); if(r.state === 'running') r.startTime -= (secs * 1000);
            } else {
                r.bonuses.count++; r.bonuses.time += secs; r.timeMs -= (secs * 1000); r.elapsed -= (secs * 1000); if(r.state === 'running') r.startTime += (secs * 1000);
            }
            if(r.timeMs < 0) { r.timeMs = 0; r.elapsed = 0; if(r.state === 'running') r.startTime = Date.now(); }
            renderGroupRunners();
        }

        function setGroupStatus(id, stat) {
            const r = groupRunners.find(runner => runner.id === id);
            if(!r) return;
            r.status = stat;
            if(stat === 'DNS' || stat === 'DNF' || stat === 'DNQ') {
                r.state = 'stopped';
                if (stat === 'DNS' || stat === 'DNF') {
                    r.timeMs = 0; r.elapsed = 0; r.penalties = {count:0,time:0}; r.bonuses = {count:0,time:0};
                }
            }
            renderGroupRunners();
        }

        function saveGroupRunner(id) {
            const r = groupRunners.find(runner => runner.id === id);
            if(!r) return;
            runs.push({
                id: Date.now() + Math.random(), name: r.name, timeMs: r.timeMs,
                timeString: (r.status === "DNF" || r.status === "DNS") ? r.status : formatTime(r.timeMs),
                status: r.status, penalties: r.penalties, bonuses: r.bonuses
            });
            saveRunsForCurrentEvent(); sortAndDisplayRuns();
            groupRunners = groupRunners.filter(runner => runner.id !== id);
            renderGroupRunners();

            if(groupRunners.length === 0) {
                document.getElementById('groupSetupForm').style.display = 'block';
                resetForm();
            }
        }

        function renderGroupRunners() {
            const container = document.getElementById('groupRunnersContainer');
            container.innerHTML = '';
            groupRunners.forEach(r => {
                const div = document.createElement('div');
                div.className = 'group-runner-row';
                
                let controls = '';
                if(r.state === 'idle') {
                    controls = `
                        <div class="group-mini-btn-row">
                            <button class="btn group-mini-btn" style="background-color: var(--status-color);" onclick="setGroupStatus(${r.id}, 'DNS')">DNS</button>
                            <button class="btn group-mini-btn" style="background-color: var(--danger);" onclick="setGroupStatus(${r.id}, 'DNF')">DNF</button>
                            <button class="btn group-mini-btn" style="background-color: #7f8c8d;" onclick="setGroupStatus(${r.id}, 'DNQ')">DNQ</button>
                        </div>`;
                } else if(r.state === 'running' || r.state === 'paused') {
                    controls = `
                        <div class="group-mini-btn-row">
                            <button class="btn group-mini-btn ${r.state === 'running' ? 'btn-pause' : 'btn-start'}" onclick="toggleGroupRunnerTimer(${r.id})">${r.state === 'running' ? 'Pause' : 'Weiter'}</button>
                            <button class="btn btn-stop group-mini-btn" onclick="stopGroupRunnerTimer(${r.id})">Stop</button>
                        </div>`;
                } else if(r.state === 'stopped') {
                    let modificationZone = '';
                    if(r.status === 'REGULÄR') {
                        modificationZone = `
                            <div style="margin: 8px 0; display:flex; flex-wrap:wrap; gap:4px;">
                                ${penaltyTypes.map(p => `<button class="btn" style="background:var(--penalty); font-size:0.75rem; padding:4px 8px;" onclick="adjustGroupTime(${r.id}, 'penalty', ${p.seconds})">${p.name}</button>`).join('')}
                                ${bonusTypes.map(b => `<button class="btn" style="background:var(--bonus); font-size:0.75rem; padding:4px 8px;" onclick="adjustGroupTime(${r.id}, 'bonus', ${b.seconds})">${b.name}</button>`).join('')}
                            </div>
                            <div style="font-size:0.85rem; font-weight:600; margin-bottom:6px; color:var(--penalty)">
                                Strafen: +${r.penalties.time}s | Boni: -${r.bonuses.time}s
                            </div>`;
                    }
                    controls = `
                        ${modificationZone}
                        <div class="group-mini-btn-row">
                            <button class="btn btn-start group-mini-btn" onclick="saveGroupRunner(${r.id})">💾 Speichern</button>
                            ${r.status === 'REGULÄR' ? `
                                <button class="btn group-mini-btn" style="background-color: var(--danger);" onclick="setGroupStatus(${r.id}, 'DNF')">DNF</button>
                                <button class="btn group-mini-btn" style="background-color: var(--status-color);" onclick="setGroupStatus(${r.id}, 'DNQ')">DNQ</button>
                            ` : ''}
                        </div>`;
                }

                div.innerHTML = `
                    <div class="group-runner-header">
                        <span class="group-runner-name-label">${escapeHTML(r.name)} ${r.status !== 'REGULÄR' ? `[${r.status}]` : ''}</span>
                        <span class="group-time-display" id="gDisplay_${r.id}">${r.status === 'DNF' || r.status === 'DNS' ? r.status : formatTime(r.timeMs)}</span>
                    </div>
                    ${controls}
                `;
                container.appendChild(div);
            });
            if (popupWindow && !popupWindow.closed) syncPopupLeaderboard();
        }

        // --- Event-Management ---
        function buildEventSelectMenu() {
            const select = document.getElementById('eventSelect'); select.innerHTML = '';
            eventList.forEach(ev => {
                const opt = document.createElement('option'); opt.value = ev;
                let statusIcon = lockedEvents.includes(ev) ? '🔒 ' : '';
                opt.innerText = ev === 'Standardlauf' ? `${statusIcon}🏁 Standardlauf` : `${statusIcon}🏆 ${ev}`;
                if (ev === currentEvent) opt.selected = true;
                select.appendChild(opt);
            });
            updateLockBtnStyle();
        }

        function openEventCreationModal() { document.getElementById('eventModal').style.display = 'flex'; document.getElementById('newEventName').focus(); }
        function closeEventModal() { document.getElementById('eventModal').style.display = 'none'; document.getElementById('newEventName').value = ''; }
        
        function createNewEvent() {
            const name = document.getElementById('newEventName').value.trim();
            if (!name || name === 'Standardlauf') { alert('Ungültiger Name.'); return; }
            if (eventList.includes(name)) { alert('Dieses Event existiert bereits.'); return; }
            eventList.push(name); localStorage.setItem('runnerEventList', JSON.stringify(eventList));
            currentEvent = name; localStorage.setItem('runnerCurrentEventName', currentEvent);
            buildEventSelectMenu(); loadRunsForCurrentEvent(); closeEventModal();
        }

        function handleEventSelectChange() {
            currentEvent = document.getElementById('eventSelect').value; localStorage.setItem('runnerCurrentEventName', currentEvent);
            loadRunsForCurrentEvent(); resetForm(); updateLockBtnStyle();
        }

        function deleteCurrentEvent() {
            if (currentEvent === 'Standardlauf') { alert('Der Standardlauf kann nicht gelöscht werden.'); return; }
            if (!confirm(`Möchtest du das Event "${currentEvent}" wirklich löschen?`)) return;
            localStorage.removeItem(`runnerLeaderboard_${currentEvent}`);
            eventList = eventList.filter(ev => ev !== currentEvent); lockedEvents = lockedEvents.filter(ev => ev !== currentEvent);
            localStorage.setItem('runnerEventList', JSON.stringify(eventList)); localStorage.setItem('runnerLockedEvents', JSON.stringify(lockedEvents));
            currentEvent = 'Standardlauf'; localStorage.setItem('runnerCurrentEventName', currentEvent);
            buildEventSelectMenu(); loadRunsForCurrentEvent(); resetForm();
        }

        function toggleLockCurrentEvent() {
            if (isRunning || groupRunners.length > 0) { alert("Bitte beende aktive Läufe zuerst."); return; }
            if (lockedEvents.includes(currentEvent)) lockedEvents = lockedEvents.filter(ev => ev !== currentEvent);
            else lockedEvents.push(currentEvent);
            localStorage.setItem('runnerLockedEvents', JSON.stringify(lockedEvents)); buildEventSelectMenu(); resetForm();
        }

        function updateLockBtnStyle() {
            const btn = document.getElementById('lockEventBtn');
            const isLocked = lockedEvents.includes(currentEvent);
            btn.innerText = isLocked ? "🔓" : "🔒";
            btn.className = isLocked ? "btn-event-action btn-lock-event is-locked" : "btn-event-action btn-lock-event";
        }

        function loadRunsForCurrentEvent() { runs = JSON.parse(localStorage.getItem(`runnerLeaderboard_${currentEvent}`)) || []; sortAndDisplayRuns(); }
        function saveRunsForCurrentEvent() { localStorage.setItem(`runnerLeaderboard_${currentEvent}`, JSON.stringify(runs)); }

        // --- Dark Mode ---
        function initTheme() {
            const savedTheme = localStorage.getItem('theme') || 'light'; document.documentElement.setAttribute('data-theme', savedTheme);
            document.getElementById('themeIcon').innerText = savedTheme === 'dark' ? "☀️" : "🌙";
            document.getElementById('themeText').innerText = savedTheme === 'dark' ? "Light Mode" : "Dark Mode";
            syncPopupTheme();
        }
        function toggleTheme() {
            const newTheme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', newTheme); localStorage.setItem('theme', newTheme); initTheme();
        }

        // --- Knöpfe verwalten ---
        function openModal(mode) {
            if (lockedEvents.includes(currentEvent)) return;
            currentModalMode = mode;
            document.getElementById('modalTitle').innerText = mode === 'add_btn_penalty' ? "Neuen Straf-Button anlegen (+)" : "Neuen Bonus-Button anlegen (-)";
            document.getElementById('customModal').style.display = 'flex'; document.getElementById('newBtnName').focus();
        }
        function closeModal() { document.getElementById('customModal').style.display = 'none'; document.getElementById('newBtnName').value = ''; document.getElementById('newBtnSeconds').value = ''; }
        
        function createNewButton() {
            const name = document.getElementById('newBtnName').value.trim(), seconds = parseInt(document.getElementById('newBtnSeconds').value, 10);
            if (!name || isNaN(seconds) || seconds <= 0) return;
            if (currentModalMode === 'add_btn_penalty') {
                penaltyTypes.push({ id: Date.now(), name: `${name} (+${seconds}s)`, seconds: seconds }); localStorage.setItem('runnerPenaltyTypes', JSON.stringify(penaltyTypes)); renderCustomButtons('penalty');
            } else {
                bonusTypes.push({ id: Date.now(), name: `${name} (-${seconds}s)`, seconds: seconds }); localStorage.setItem('runnerBonusTypes', JSON.stringify(bonusTypes)); renderCustomButtons('bonus');
            }
            closeModal(); renderGroupRunners();
        }

        function deleteCustomType(id, mode, event) {
            event.stopPropagation();
            if (mode === 'penalty') { penaltyTypes = penaltyTypes.filter(p => p.id !== id); localStorage.setItem('runnerPenaltyTypes', JSON.stringify(penaltyTypes)); renderCustomButtons('penalty'); }
            else { bonusTypes = bonusTypes.filter(b => b.id !== id); localStorage.setItem('runnerBonusTypes', JSON.stringify(bonusTypes)); renderCustomButtons('bonus'); }
            renderGroupRunners();
        }

        function renderCustomButtons(mode) {
            const container = document.getElementById(mode === 'penalty' ? 'dynamicPenaltyGroup' : 'dynamicBonusGroup'); container.innerHTML = '';
            const targetArray = mode === 'penalty' ? penaltyTypes : bonusTypes;
            if (targetArray.length === 0) { container.innerHTML = `<span style="color:var(--text-light); font-style:italic; font-size:0.9rem;">Keine</span>`; return; }
            
            const isSaveDisabled = document.getElementById('saveBtn').disabled || lockedEvents.includes(currentEvent);
            targetArray.forEach(item => {
                const wrapper = document.createElement('div'); wrapper.className = `custom-btn-container type-${mode}`;
                const mainBtn = document.createElement('button'); mainBtn.className = 'btn-custom-action'; mainBtn.innerText = item.name; mainBtn.disabled = isSaveDisabled;
                mainBtn.onclick = () => handleTimeAdjustment(mode, item.seconds);
                const delBtn = document.createElement('button'); delBtn.className = 'delete-custom-type-btn'; delBtn.innerHTML = '&times;'; delBtn.disabled = lockedEvents.includes(currentEvent);
                delBtn.onclick = (e) => deleteCustomType(item.id, mode, e);
                wrapper.appendChild(mainBtn); wrapper.appendChild(delBtn); container.appendChild(wrapper);
            });
        }

        function setActionButtonsDisabled(disabled) {
            const isLocked = lockedEvents.includes(currentEvent);
            document.querySelectorAll('#tabSingleContent .btn-custom-action').forEach(btn => btn.disabled = disabled || isLocked);
            document.getElementById('statusBtnDNQ').disabled = disabled || isLocked;
        }

        function formatTime(totalMilliseconds) {
            if (totalMilliseconds < 0) totalMilliseconds = 0;
            let hours = Math.floor(totalMilliseconds / 3600000), minutes = Math.floor((totalMilliseconds % 3600000) / 60000);
            let seconds = Math.floor((totalMilliseconds % 60000) / 1000), hundredths = Math.floor((totalMilliseconds % 1000) / 10);
            return ((hours < 10 ? "0" : "") + hours + ":" + (minutes < 10 ? "0" : "") + minutes + ":" + (seconds < 10 ? "0" : "") + seconds + "." + (hundredths < 10 ? "0" : "") + hundredths);
        }

        // --- Zeitmessung (Einzel) ---
        function toggleTimer() {
            if (lockedEvents.includes(currentEvent)) return;
            if (!document.getElementById('runnerName').value.trim()) { alert("Bitte Namen eingeben."); return; }
            
            const startBtn = document.getElementById('startBtn');
            if (currentStatus === "DNS" || currentStatus === "DNF" || currentStatus === "DNQ") { currentStatus = "REGULÄR"; document.getElementById('display').innerText = "00:00:00.00"; updateAdjustmentNoticeDisplay(); }

            if (!isRunning) {
                isRunning = true; isPaused = false; startTime = Date.now() - elapsedBeforePause;
                timerInterval = setInterval(() => {
                    currentTotalMs = Date.now() - startTime; const formatted = formatTime(currentTotalMs);
                    document.getElementById('display').innerText = formatted; syncPopupTime(formatted);
                }, 10);
                startBtn.innerText = "Pause"; startBtn.className = "btn btn-pause";
                document.getElementById('stopBtn').disabled = false; document.getElementById('saveBtn').disabled = true; document.getElementById('runnerName').disabled = true;
                document.getElementById('statusBtnDNS').disabled = true; document.getElementById('statusBtnDNF').disabled = true; setActionButtonsDisabled(true);
            } else {
                isRunning = false; isPaused = true; clearInterval(timerInterval); elapsedBeforePause = currentTotalMs;
                startBtn.innerText = "Weiter"; startBtn.className = "btn btn-start";
            }
        }

        function stopTimer() {
            isRunning = false; isPaused = false; clearInterval(timerInterval);
            document.getElementById('startBtn').disabled = true; document.getElementById('startBtn').innerText = "Start"; document.getElementById('startBtn').className = "btn btn-start";
            document.getElementById('stopBtn').disabled = true; document.getElementById('saveBtn').disabled = lockedEvents.includes(currentEvent); setActionButtonsDisabled(false);
        }

        function handleTimeAdjustment(mode, seconds) {
            if (lockedEvents.includes(currentEvent) || currentStatus === "DNF" || currentStatus === "DNS") return;
            if (mode === 'penalty') { penaltyCount++; penaltyTime += seconds; currentTotalMs += (seconds * 1000); elapsedBeforePause += (seconds * 1000); if(isRunning) startTime -= (seconds * 1000); } 
            else { bonusCount++; bonusTime += seconds; currentTotalMs -= (seconds * 1000); elapsedBeforePause -= (seconds * 1000); if(isRunning) startTime += (seconds * 1000); }
            if (currentTotalMs < 0) { currentTotalMs = 0; elapsedBeforePause = 0; if(isRunning) startTime = Date.now(); }
            const formatted = formatTime(currentTotalMs); document.getElementById('display').innerText = formatted; syncPopupTime(formatted); updateAdjustmentNoticeDisplay();
        }

        // --- Status (Einzel) ---
        function handleStatusSet(status) {
            if (lockedEvents.includes(currentEvent)) return;
            if (!document.getElementById('runnerName').value.trim()) { alert("Bitte einen Namen für den Läufer eingeben."); return; }
            currentStatus = status;
            if (status === "DNF" || status === "DNS" || status === "DNQ") {
                isRunning = false; isPaused = false; clearInterval(timerInterval); 
                if (status === "DNF" || status === "DNS") {
                    currentTotalMs = 0; elapsedBeforePause = 0; penaltyCount = 0; penaltyTime = 0; bonusCount = 0; bonusTime = 0;
                    document.getElementById('display').innerText = "--:--:--.--"; syncPopupTime(status);
                }
                document.getElementById('startBtn').disabled = true; document.getElementById('stopBtn').disabled = true; document.getElementById('saveBtn').disabled = false; document.getElementById('runnerName').disabled = true;
            }
            updateAdjustmentNoticeDisplay();
        }

        function updateAdjustmentNoticeDisplay() {
            const notice = document.getElementById('adjustmentNotice');
            if (currentStatus !== "REGULÄR") { notice.innerText = `Status: ${currentStatus}`; notice.className = "adjustment-display status-info"; } 
            else {
                let text = ""; if (penaltyTime > 0) text += `+${penaltyTime}s Strafe `; if (bonusTime > 0) text += `-${bonusTime}s Bonus`;
                notice.innerText = text.trim(); notice.className = `adjustment-display ${penaltyTime >= bonusTime ? 'penalty' : 'bonus'}`;
            }
            syncPopupNotice();
        }

        function saveRun() {
            if (lockedEvents.includes(currentEvent)) return;
            runs.push({
                id: Date.now(), name: document.getElementById('runnerName').value.trim(), timeMs: currentTotalMs,
                timeString: (currentStatus === "DNF" || currentStatus === "DNS") ? currentStatus : formatTime(currentTotalMs),
                status: currentStatus, penalties: { count: penaltyCount, time: penaltyTime }, bonuses: { count: bonusCount, time: bonusTime }
            });
            saveRunsForCurrentEvent(); sortAndDisplayRuns(); resetForm();
        }

        function resetForm() {
            isRunning = false; isPaused = false; clearInterval(timerInterval); elapsedBeforePause = 0; currentTotalMs = 0; penaltyCount = 0; penaltyTime = 0; bonusCount = 0; bonusTime = 0; currentStatus = "REGULÄR";
            const isLocked = lockedEvents.includes(currentEvent);
            document.getElementById('timingCard').style.display = isLocked ? 'none' : 'block';
            document.getElementById('runnerName').value = ""; document.getElementById('runnerName').disabled = isLocked;
            document.getElementById('display').innerText = "00:00:00.00"; document.getElementById('adjustmentNotice').innerText = "";
            document.getElementById('startBtn').disabled = isLocked; document.getElementById('stopBtn').disabled = true; document.getElementById('saveBtn').disabled = true;
            document.getElementById('statusBtnDNS').disabled = isLocked; document.getElementById('statusBtnDNF').disabled = isLocked; document.getElementById('statusBtnDNQ').disabled = true;
            document.getElementById('addPenaltyTypeBtn').disabled = isLocked; document.getElementById('addBonusTypeBtn').disabled = isLocked;
            document.querySelectorAll('#tabSingleContent .btn-custom-action').forEach(btn => { if (btn.id !== 'statusBtnDNS' && btn.id !== 'statusBtnDNF' && btn.id !== 'statusBtnDNQ') btn.setAttribute('disabled', 'true'); });
            renderCustomButtons('penalty'); renderCustomButtons('bonus'); groupRunners = []; renderGroupRunners();
            document.getElementById('groupSetupForm').style.display = 'block'; document.getElementById('groupMassActionRow').style.display = 'none';
            syncPopupRunnerName(); syncPopupTime(isLocked ? "GEBLOCKT" : "00:00:00.00"); syncPopupNotice();
        }

        function sortAndDisplayRuns() {
            runs.sort((a, b) => {
                const statusOrder = { "REGULÄR": 1, "DNQ": 2, "DNF": 3, "DNS": 4 };
                if (statusOrder[a.status] !== statusOrder[b.status]) return statusOrder[a.status] - statusOrder[b.status];
                if (a.status === "REGULÄR" || a.status === "DNQ") return a.timeMs - b.timeMs;
                return a.name.localeCompare(b.name);
            });
            const ol = document.getElementById('leaderboard'); ol.innerHTML = "";
            if (runs.length === 0) { ol.innerHTML = '<li class="empty-state">Noch keine Läufe registriert.</li>'; if (popupWindow && !popupWindow.closed) syncPopupLeaderboard(); return; }
            runs.forEach((run, index) => {
                const li = document.createElement('li'); li.className = "leaderboard-item";
                let badges = '';
                if (run.status !== "REGULÄR") badges += `<span class="badge badge-status">${run.status}</span>`;
                if (run.penalties?.time > 0) badges += `<span class="badge badge-penalty">${run.penalties.count}x Strafe (+${run.penalties.time}s)</span>`;
                if (run.bonuses?.time > 0) badges += `<span class="badge badge-bonus">${run.bonuses.count}x Bonus (-${run.bonuses.time}s)</span>`;
                li.innerHTML = `
                    <div class="runner-info"><span class="rank">#${index + 1}</span><div><div class="runner-name">${escapeHTML(run.name)}</div><div class="stats-badges">${badges}</div></div></div>
                    <div class="right-side-container"><span class="runner-time">${run.timeString}</span><button class="action-btn edit-btn" onclick="openEditModal(${run.id})">📝</button><button class="action-btn delete-btn" onclick="deleteRun(${run.id})">&times;</button></div>`;
                ol.appendChild(li);
            });
            if (popupWindow && !popupWindow.closed) syncPopupLeaderboard();
        }

        function deleteRun(id) { runs = runs.filter(r => r.id !== id); saveRunsForCurrentEvent(); sortAndDisplayRuns(); }

        // --- Bearbeiten ---
        function openEditModal(id) {
            const run = runs.find(r => r.id === id); if (!run) return;
            document.getElementById('editRunId').value = run.id; document.getElementById('editRunnerName').value = run.name; document.getElementById('editStatus').value = run.status;
            let totalMs = run.timeMs || 0;
            document.getElementById('editHours').value = Math.floor(totalMs / 3600000);
            document.getElementById('editMinutes').value = Math.floor((totalMs % 3600000) / 60000);
            document.getElementById('editSeconds').value = Math.floor((totalMs % 60000) / 1000);
            document.getElementById('editHundredths').value = Math.floor((totalMs % 1000) / 10);
            
            document.getElementById('editPenaltyCount').value = run.penalties ? run.penalties.count : 0;
            document.getElementById('editPenaltyTime').value = run.penalties ? run.penalties.time : 0;
            document.getElementById('editBonusCount').value = run.bonuses ? run.bonuses.count : 0;
            document.getElementById('editBonusTime').value = run.bonuses ? run.bonuses.time : 0;

            toggleEditTimeField(); document.getElementById('editModal').style.display = 'flex';
        }
        function closeEditModal() { document.getElementById('editModal').style.display = 'none'; }
        function toggleEditTimeField() { document.getElementById('editTimeGroup').style.display = (document.getElementById('editStatus').value === "DNF" || document.getElementById('editStatus').value === "DNS") ? 'none' : 'flex'; }
        
        function submitEditRun() {
            const id = parseFloat(document.getElementById('editRunId').value); const runIndex = runs.findIndex(r => r.id === id); if (runIndex === -1) return;
            const stat = document.getElementById('editStatus').value; let timeMs = 0;
            
            let pCount = parseInt(document.getElementById('editPenaltyCount').value, 10) || 0;
            let pTime = parseInt(document.getElementById('editPenaltyTime').value, 10) || 0;
            let bCount = parseInt(document.getElementById('editBonusCount').value, 10) || 0;
            let bTime = parseInt(document.getElementById('editBonusTime').value, 10) || 0;

            if (stat !== "DNF" && stat !== "DNS") {
                timeMs = (parseInt(document.getElementById('editHours').value, 10)||0)*3600000 + (parseInt(document.getElementById('editMinutes').value, 10)||0)*60000 + (parseInt(document.getElementById('editSeconds').value, 10)||0)*1000 + (parseInt(document.getElementById('editHundredths').value, 10)||0)*10;
            } else { pCount = 0; pTime = 0; bCount = 0; bTime = 0; }
            
            runs[runIndex] = { 
                id: id, name: document.getElementById('editRunnerName').value.trim()||"Unbekannt", status: stat, timeMs: timeMs, 
                timeString: (stat==="DNF"||stat==="DNS")?stat:formatTime(timeMs),
                penalties: { count: pCount, time: pTime }, bonuses: { count: bCount, time: bTime }
            };
            saveRunsForCurrentEvent(); sortAndDisplayRuns(); closeEditModal();
        }

        // --- JSON Daten-Management (Import & Export) ---
        function exportJSONData() {
            if (runs.length === 0) { alert("Keine Daten zum Exportieren vorhanden."); return; }
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(runs, null, 2));
            const downloadAnchor = document.createElement('a');
            const fileName = `Bestenliste_${currentEvent.replace(/[^a-z0-9]/gi, '_')}.json`;
            downloadAnchor.setAttribute("href", dataStr);
            downloadAnchor.setAttribute("download", fileName);
            document.body.appendChild(downloadAnchor);
            downloadAnchor.click();
            downloadAnchor.remove();
        }

        function triggerJSONImport() {
            if (lockedEvents.includes(currentEvent)) { alert("Dieses Event ist abgeschlossen. Import blockiert."); return; }
            document.getElementById('jsonImportInput').click();
        }

        function importJSONData(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const importedRuns = JSON.parse(e.target.result);
                    if (!Array.isArray(importedRuns)) throw new Error("Format ungültig.");

                    const isValid = importedRuns.every(run => 
                        run.hasOwnProperty('name') && 
                        run.hasOwnProperty('status') && 
                        run.hasOwnProperty('timeMs') && 
                        run.hasOwnProperty('timeString')
                    );

                    if (!isValid) {
                        alert("Die JSON-Datei enthält kein gültiges Format für Läufe.");
                        return;
                    }

                    if (confirm(`Möchtest du ${importedRuns.length} Läufe in das Event "${currentEvent}" importieren? Existierende Läufe werden überschrieben.`)) {
                        runs = importedRuns;
                        saveRunsForCurrentEvent();
                        sortAndDisplayRuns();
                        alert("Daten erfolgreich importiert!");
                    }
                } catch (err) {
                    alert("Fehler beim Lesen der JSON-Datei. Vergewissere dich, dass die Datei unbeschädigt ist.");
                }
                document.getElementById('jsonImportInput').value = '';
            };
            reader.readAsText(file);
        }

        // --- Popup Leinwand-Logik ---
        function openScreenPopup() {
            if (popupWindow && !popupWindow.closed) { popupWindow.focus(); return; }
            popupWindow = window.open("", "LeinwandAnsicht", "width=1000,height=600,scrollbars=yes,resizable=yes");
            popupWindow.document.write(`
                <!DOCTYPE html>
                <html>
                <head>
                    <title>Live-Anzeige Zeitmessung</title>
                    <style>
                        :root { --bg-color: #f4f7f6; --card-bg: #ffffff; --primary: #2c3e50; --accent: #3498db; --danger: #e74c3c; --success: #2ecc71; --text: #333333; --border-color: #dddddd; --penalty: #f39c12; --bonus: #9b59b6; --status: #7f8c8d; }
                        [data-theme="dark"] { --bg-color: #1a1a1a; --card-bg: #2d2d2d; --primary: #ecf0f1; --accent: #5dade2; --text: #e0e0e0; --border-color: #444444; }
                        body { font-family: 'Segoe UI', Arial, sans-serif; background-color: var(--bg-color); color: var(--text); margin: 0; padding: 20px; height: 100vh; box-sizing: border-box; display: flex; gap: 20px; }
                        .left-pane { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; background: var(--card-bg); border-radius: 12px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); text-align: center; overflow-y: auto; }
                        .right-pane { width: 350px; background: var(--card-bg); border-radius: 12px; padding: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); display: flex; flex-direction: column; overflow: hidden; }
                        #pRunnerName { font-size: 2.5rem; font-weight: bold; color: var(--accent); margin: 0 0 20px 0; min-height: 3.5rem; word-break: break-word; }
                        #pDisplay { font-family: 'Courier New', monospace; font-size: 5.5rem; font-weight: bold; color: var(--primary); letter-spacing: 2px; margin: 20px 0; }
                        #pNotice { font-size: 1.8rem; font-weight: 600; min-height: 2.5rem; }
                        .notice-penalty { color: var(--danger); } .notice-bonus { color: var(--success); } .notice-status { color: var(--status); }
                        h2 { margin-top: 0; border-bottom: 2px solid var(--bg-color); padding-bottom: 10px; font-size: 1.4rem; color: var(--primary); }
                        .pop-list { list-style: none; padding: 0; margin: 0; overflow-y: auto; flex: 1; }
                        .pop-item { display: flex; justify-content: space-between; align-items: center; padding: 10px 5px; border-bottom: 1px solid var(--border-color); font-size: 1.05rem; }
                        .pop-rank { font-weight: bold; color: var(--accent); margin-right: 10px; }
                        .pop-time { font-family: 'Courier New', monospace; font-weight: bold; }
                        .p-badge { font-size: 0.7rem; padding: 1px 4px; border-radius: 3px; color: white; font-weight: bold; margin-left: 4px; display: inline-block; }
                        .pb-p { background-color: var(--penalty); } .pb-b { background-color: var(--bonus); } .pb-s { background-color: var(--status); }
                        .multi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 15px; width: 100%; }
                        .multi-box { background: var(--bg-color); padding: 15px; border-radius: 8px; box-shadow: inset 0 0 5px rgba(0,0,0,0.05); }
                        .multi-name { font-size: 1.5rem; font-weight: bold; color: var(--accent); }
                        .multi-time { font-family: 'Courier New', monospace; font-size: 2.5rem; font-weight: bold; margin: 10px 0; }
                    </style>
                </head>
                <body>
                    <div class="left-pane" id="pLeftPane">
                        <div id="pRunnerName">Bereit...</div>
                        <div id="pDisplay">00:00:00.00</div>
                        <div id="pNotice"></div>
                    </div>
                    <div class="right-pane">
                        <h2>🏆 Bestenliste</h2>
                        <ol id="pLeaderboard" class="pop-list"></ol>
                    </div>
                </body>
                </html>
            `);
            popupWindow.document.close(); syncPopupTheme(); syncPopupRunnerName(); syncPopupNotice(); syncPopupLeaderboard();
        }

        function syncPopupTheme() { if (popupWindow && !popupWindow.closed) popupWindow.document.documentElement.setAttribute('data-theme', document.documentElement.getAttribute('data-theme') || 'light'); }
        function syncPopupRunnerName() {
            if (!popupWindow || popupWindow.closed || activeTab === 'group') return;
            popupWindow.document.getElementById('pRunnerName').innerText = document.getElementById('runnerName').value.trim() || (lockedEvents.includes(currentEvent) ? "Gesperrt" : "Bereit...");
        }
        function syncPopupTime(timeString) { if (popupWindow && !popupWindow.closed && activeTab === 'single') popupWindow.document.getElementById('pDisplay').innerText = timeString; }
        function syncPopupNotice() {
            if (!popupWindow || popupWindow.closed || activeTab === 'group') return;
            const el = popupWindow.document.getElementById('pNotice');
            if (currentStatus !== "REGULÄR") { el.innerText = `Status: ${currentStatus}`; el.className = "notice-status"; } 
            else { el.innerText = ((penaltyTime > 0 ? `+${penaltyTime}s ` : '') + (bonusTime > 0 ? `-${bonusTime}s` : '')).trim(); el.className = penaltyTime >= bonusTime ? "notice-penalty" : "notice-bonus"; }
        }
        
        function syncPopupLeaderboard() {
            if (!popupWindow || popupWindow.closed) return;
            const pOl = popupWindow.document.getElementById('pLeaderboard'); pOl.innerHTML = "";
            if (runs.length === 0) pOl.innerHTML = '<li style="text-align:center;color:#7f8c8d;font-style:italic;padding-top:20px;">Keine Läufe</li>';
            else {
                runs.forEach((run, index) => {
                    const li = popupWindow.document.createElement('li'); li.className = "pop-item";
                    let tags = (run.status !== "REGULÄR" ? `<span class="p-badge pb-s">${run.status}</span>` : '') + (run.penalties?.time > 0 ? `<span class="p-badge pb-p">+${run.penalties.time}s</span>` : '') + (run.bonuses?.time > 0 ? `<span class="p-badge pb-b">-${run.bonuses.time}s</span>` : '');
                    li.innerHTML = `<div><span class="pop-rank">#${index+1}</span><span>${escapeHTML(run.name)}${tags}</span></div><div class="pop-time">${run.timeString}</div>`;
                    pOl.appendChild(li);
                });
            }

            const leftPane = popupWindow.document.getElementById('pLeftPane');
            if(activeTab === 'single') {
                if(!popupWindow.document.getElementById('pDisplay')) {
                    leftPane.innerHTML = '<div id="pRunnerName">Bereit...</div><div id="pDisplay">00:00:00.00</div><div id="pNotice"></div>';
                    syncPopupRunnerName(); syncPopupNotice();
                }
            } else {
                if(groupRunners.length === 0) {
                    leftPane.innerHTML = '<div style="font-size:2rem; font-weight:bold; color:var(--text-light)">Gruppenlauf: Bereitstellung...</div>';
                } else {
                    leftPane.innerHTML = `<div class="multi-grid">${groupRunners.map(r => `
                        <div class="multi-box">
                            <div class="multi-name">${escapeHTML(r.name)} ${r.status !== 'REGULÄR'?'['+r.status+']':''}</div>
                            <div class="multi-time">${r.status==='DNF'||r.status==='DNS'?r.status:formatTime(r.timeMs)}</div>
                            <div style="font-size:0.9rem; color:var(--text-light)">Strafen: +${r.penalties.time}s | Boni: -${r.bonuses.time}s</div>
                        </div>`).join('')}</div>`;
                }
            }
        }

        // --- Export ---
        function prepareExportStyles() {
            const element = document.getElementById('leaderboardCard'), cardHeader = document.getElementById('cardHeader');
            const pdfEventTitle = document.getElementById('pdfEventTitle'), actionButtons = element.querySelectorAll('.action-btn');
            pdfEventTitle.innerText = currentEvent === 'Standardlauf' ? "🏆 Bestenliste" : currentEvent;
            cardHeader.style.display = 'none'; pdfEventTitle.style.display = 'block'; actionButtons.forEach(btn => btn.style.display = 'none'); element.classList.add('pdf-export-mode');
            return () => { cardHeader.style.display = 'flex'; pdfEventTitle.style.display = 'none'; actionButtons.forEach(btn => btn.style.display = 'inline-block'); element.classList.remove('pdf-export-mode'); };
        }

        function exportToPDF() {
            if (runs.length === 0) return; const resetStyles = prepareExportStyles();
            const safeFileName = `Bestenliste_${currentEvent.replace(/[^a-z0-9]/gi, '_')}.pdf`;
            html2pdf().set({ margin: 15, filename: safeFileName, image: { type: 'jpeg', quality: 0.98 }, html2canvas: { scale: 2, useCORS: true }, jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' } }).from(document.getElementById('leaderboardCard')).save().then(resetStyles);
        }

        async function shareAsImage() {
            if (runs.length === 0) return; const resetStyles = prepareExportStyles();
            try {
                const canvas = await html2canvas(document.getElementById('leaderboardCard'), { scale: 2, backgroundColor: '#ffffff' }); resetStyles();
                canvas.toBlob(async (blob) => {
                    const file = new File([blob], 'bestenliste.png', { type: 'image/png' });
                    if (navigator.canShare && navigator.canShare({ files: [file] })) await navigator.share({ files: [file], title: 'Ergebnisse' });
                    else { const a = document.createElement('a'); a.href = canvas.toDataURL('image/png'); a.download = 'Bestenliste.png'; a.click(); }
                });
            } catch (err) { resetStyles(); }
        }

        function escapeHTML(str) { return str.replace(/[&<>'"]/g, tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)); }
    </script>
</body>
</html>
