<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zeitmessung & Bestenliste</title>
    <style>
        :root {
            --bg-color: #f4f7f6;
            --card-bg: #ffffff;
            --primary: #2c3e50;
            --accent: #3498db;
            --danger: #e74c3c;
            --success: #2ecc71;
            --text: #333333;
            --text-light: #7f8c8d;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text);
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .container {
            width: 100%;
            max-width: 600px;
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .card {
            background: var(--card-bg);
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            padding: 25px;
        }

        h2 {
            margin-top: 0;
            color: var(--primary);
            border-bottom: 2px solid var(--bg-color);
            padding-bottom: 10px;
            font-size: 1.5rem;
        }

        /* Bestenliste */
        .leaderboard-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .leaderboard-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 10px;
            border-bottom: 1px solid #eee;
            transition: background 0.2s;
        }

        .leaderboard-item:last-child {
            border-bottom: none;
        }

        .leaderboard-item:hover {
            background-color: #fafafa;
        }

        .runner-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .rank {
            font-weight: bold;
            color: var(--accent);
            width: 25px;
        }

        .runner-name {
            font-weight: 500;
        }

        .runner-time {
            font-family: 'Courier New', Courier, monospace;
            font-weight: bold;
            color: var(--primary);
            margin-right: 15px;
        }

        .delete-btn {
            background: none;
            border: none;
            color: var(--text-light);
            font-size: 1.2rem;
            cursor: pointer;
            transition: color 0.2s;
            padding: 0 5px;
        }

        .delete-btn:hover {
            color: var(--danger);
        }

        .empty-state {
            text-align: center;
            color: var(--text-light);
            font-style: italic;
        }

        /* Zeitmessung Formular & Display */
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 20px;
        }

        label {
            font-weight: 600;
            color: var(--primary);
        }

        input[type="text"] {
            padding: 12px;
            border: 2px solid #ddd;
            border-radius: 8px;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.2s;
        }

        input[type="text"]:focus {
            border-color: var(--accent);
        }

        .stopwatch-display {
            font-family: 'Courier New', Courier, monospace;
            font-size: 3rem;
            text-align: center;
            font-weight: bold;
            color: var(--primary);
            margin: 20px 0;
            letter-spacing: 2px;
        }

        .penalty-display {
            text-align: center;
            color: var(--danger);
            font-weight: 600;
            height: 20px;
            margin-bottom: 15px;
        }

        /* Buttons */
        .btn-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 15px;
        }

        .btn {
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.1s;
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .btn:active {
            transform: scale(0.98);
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .btn-start { background-color: var(--success); }
        .btn-stop { background-color: var(--danger); }
        .btn-penalty { background-color: #f39c12; }
        .btn-save { background-color: var(--accent); grid-column: span 2; }
    </style>
</head>
<body>

    <div class="container">
        
        <div class="card">
            <h2>🏆 Bestenliste</h2>
            <ol id="leaderboard" class="leaderboard-list">
                </ol>
        </div>

        <div class="card">
            <h2>⏱️ Neuer Lauf</h2>
            
            <div class="form-group">
                <label for="runnerName">Name des Läufers:</label>
                <input type="text" id="runnerName" placeholder="z.B. Max Mustermann" autocomplete="off">
            </div>

            <div class="stopwatch-display" id="display">00:00:00.00</div>
            <div class="penalty-display" id="penaltyNotice"></div>

            <div class="btn-group">
                <button class="btn btn-start" id="startBtn" onclick="startTimer()">Start</button>
                <button class="btn btn-stop" id="stopBtn" onclick="stopTimer()" disabled>Stop</button>
            </div>

            <div class="btn-group">
                <button class="btn btn-penalty" id="penalty5Btn" onclick="addPenalty(5)" disabled>+5s Strafe</button>
                <button class="btn btn-penalty" id="penalty15Btn" onclick="addPenalty(15)" disabled>+15s Strafe</button>
            </div>

            <div class="btn-group">
                <button class="btn btn-save" id="saveBtn" onclick="saveRun()" disabled>Lauf Speichern</button>
            </div>
        </div>

    </div>

    <script>
        // Variablen für die Zeitmessung
        let startTime = 0;
        let elapsedTime = 0;
        let timerInterval = null;
        let penaltySeconds = 0;
        let currentTotalMs = 0;

        // Bestenliste aus dem LocalStorage laden
        let runs = JSON.parse(localStorage.getItem('runnerLeaderboard')) || [];

        window.onload = function() {
            updateLeaderboardDisplay();
        };

        // Formatierungsfunktion (hh:mm:ss.hh)
        function formatTime(totalMilliseconds) {
            let hours = Math.floor(totalMilliseconds / 3600000);
            let minutes = Math.floor((totalMilliseconds % 3600000) / 60000);
            let seconds = Math.floor((totalMilliseconds % 60000) / 1000);
            let hundredths = Math.floor((totalMilliseconds % 1000) / 10);

            return (
                (hours < 10 ? "0" : "") + hours + ":" +
                (minutes < 10 ? "0" : "") + minutes + ":" +
                (seconds < 10 ? "0" : "") + seconds + "." +
                (hundredths < 10 ? "0" : "") + hundredths
            );
        }

        // Timer starten
        function startTimer() {
            const nameInput = document.getElementById('runnerName').value.trim();
            if (!nameInput) {
                alert("Eure Exzellenz, bitte gebt zuerst einen Namen für den Läufer ein.");
                return;
            }

            elapsedTime = 0;
            penaltySeconds = 0;
            currentTotalMs = 0;
            document.getElementById('penaltyNotice').innerText = "";
            
            startTime = Date.now();
            
            timerInterval = setInterval(function() {
                elapsedTime = Date.now() - startTime;
                currentTotalMs = elapsedTime;
                document.getElementById('display').innerText = formatTime(currentTotalMs);
            }, 10);

            document.getElementById('runnerName').disabled = true;
            document.getElementById('startBtn').disabled = true;
            document.getElementById('stopBtn').disabled = false;
            document.getElementById('penalty5Btn').disabled = true;
            document.getElementById('penalty15Btn').disabled = true;
            document.getElementById('saveBtn').disabled = true;
        }

        // Timer stoppen
        function stopTimer() {
            clearInterval(timerInterval);
            
            document.getElementById('stopBtn').disabled = true;
            document.getElementById('penalty5Btn').disabled = false;
            document.getElementById('penalty15Btn').disabled = false;
            document.getElementById('saveBtn').disabled = false;
        }

        // Strafsekunden addieren
        function addPenalty(seconds) {
            penaltySeconds += seconds;
            currentTotalMs += (seconds * 1000);
            
            document.getElementById('display').innerText = formatTime(currentTotalMs);
            document.getElementById('penaltyNotice').innerText = `+${penaltySeconds}s Strafe aktiv`;
        }

        // Lauf speichern
        function saveRun() {
            const name = document.getElementById('runnerName').value.trim();
            
            const newRun = {
                id: Date.now(),
                name: name,
                timeMs: currentTotalMs,
                timeString: formatTime(currentTotalMs)
            };

            runs.push(newRun);
            
            // GEÄNDERT: Sortierung nach Zeit AUFSTEIGEND (a - b -> kleinste Zeit zuerst)
            runs.sort((a, b) => a.timeMs - b.timeMs);

            localStorage.setItem('runnerLeaderboard', JSON.stringify(runs));
            updateLeaderboardDisplay();
            resetForm();
        }

        // Formular zurücksetzen
        function resetForm() {
            document.getElementById('runnerName').value = "";
            document.getElementById('runnerName').disabled = false;
            document.getElementById('display').innerText = "00:00:00.00";
            document.getElementById('penaltyNotice').innerText = "";
            document.getElementById('startBtn').disabled = false;
            document.getElementById('penalty5Btn').disabled = true;
            document.getElementById('penalty15Btn').disabled = true;
            document.getElementById('saveBtn').disabled = true;
            
            elapsedTime = 0;
            penaltySeconds = 0;
            currentTotalMs = 0;
        }

        // Bestenliste anzeigen
        function updateLeaderboardDisplay() {
            const leaderboardOl = document.getElementById('leaderboard');
            leaderboardOl.innerHTML = "";

            if (runs.length === 0) {
                leaderboardOl.innerHTML = '<li class="empty-state">Noch keine Läufe registriert, Mein Lehnsherr.</li>';
                return;
            }

            runs.forEach((run, index) => {
                const li = document.createElement('li');
                li.className = "leaderboard-item";
                
                li.innerHTML = `
                    <div class="runner-info">
                        <span class="rank">#${index + 1}</span>
                        <span class="runner-name">${escapeHTML(run.name)}</span>
                    </div>
                    <div>
                        <span class="runner-time">${run.timeString}</span>
                        <button class="delete-btn" onclick="deleteRun(${run.id})" title="Lauf löschen">&times;</button>
                    </div>
                `;
                leaderboardOl.appendChild(li);
            });
        }

        // Einen Lauf löschen
        function deleteRun(id) {
            runs = runs.filter(run => run.id !== id);
            localStorage.setItem('runnerLeaderboard', JSON.stringify(runs));
            updateLeaderboardDisplay();
        }

        // Schutz gegen XSS
        function escapeHTML(str) {
            return str.replace(/[&<>'"]/g, 
                tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
            );
        }
    </script>
</body>
</html>
